# Backend Environment Variables
# For PostgreSQL (production):
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/pulseapi
# For SQLite (development):
DATABASE_URL=sqlite:///./pulseapi.db
SECRET_KEY=change-this-to-a-random-secret-key
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# SendGrid API (email verification)
# Get a free API key at https://sendgrid.com (100 emails/day free)
SENDGRID_API_KEY=SG.example_your_sendgrid_api_key_here
SENDGRID_FROM_EMAIL=PulseAPI <noreply@example.com>
